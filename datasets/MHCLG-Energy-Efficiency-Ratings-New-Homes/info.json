{
    "$schema": "http://gss-cogs.github.io/family-schemas/dataset-schema-1.1.0.json",
    "id": "mhclg-energy-efficiency-ratings-new-homes",
    "title": "Energy Efficiency Ratings New Homes",
    "publisher": "Ministry for Housing, Communities and Local Government",
    "description": "Summary of energy efficiency rating by new homes",
    "landingPage": "Not available",
    "datasetNotes": [
        "Although I've added a landing page for this dataset, it's actually a bespoke CSV dataset supplied by Climate Change team. The landing page is the source data from which the CC took the origianl data."
    ],
    "published": "2020",
    "families": [
        "Climate-Change"
    ],
    "extract": {
        "source": "CSV"
    },
    "transform": {
        "airtable": "rec0VBQYZbSpRmDt7",
        "main_issue": 91,
        "columns": {
            "Year": {
                "type": "dimension",
                "uri": "http://purl.org/linked-data/sdmx/2009/dimension#refPeriod",
                "value": "http://reference.data.gov.uk/id/year/{+year}"
            },
            "Measure Type": {
                "type": "measures",
                "value": "http://gss-data.org.uk/def/climate-change/measure/{+measure_type}"
            },
            "Unit": {
                "type": "units",
                "value": "http://gss-data.org.uk/def/concept/measurement-units/{+unit}"
            },
            "Value": {
                "type": "observations",
                "datatype": "integer"        
            }
        }
    },
    "sizingNotes": "",
    "notes": "Priority dataset for Climate Change Platform project."
}